        "respondWith": "text",
        "responseBody": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>RecebAI</title>\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { font-family: 'DM Sans', sans-serif; background: #f4f6fb; display: flex; min-height: 100vh; }\n.sidebar { width: 220px; background: #1a1a2e; color: #fff; padding: 0; display: flex; flex-direction: column; flex-shrink: 0; }\n.sidebar-logo { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }\n.sidebar-logo h1 { font-size: 20px; font-weight: 600; color: #fff; }\n.sidebar-logo span { color: #4f8ef7; }\n.sidebar-logo p { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 2px; }\n.nav { padding: 12px 0; flex: 1; }\n.nav-item { display: flex; align-items: center; gap: 10px; padding: 11px 20px; cursor: pointer; font-size: 14px; color: rgba(255,255,255,0.55); transition: all 0.15s; border-left: 3px solid transparent; }\n.nav-item:hover { background: rgba(255,255,255,0.05); color: #fff; }\n.nav-item.active { background: rgba(79,142,247,0.12); color: #4f8ef7; border-left-color: #4f8ef7; }\n.nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }\n.main { flex: 1; padding: 32px; overflow-y: auto; }\n.page { display: none; }\n.page.active { display: block; }\n.page-title { font-size: 22px; font-weight: 600; color: #1a1a2e; margin-bottom: 6px; }\n.page-sub { font-size: 14px; color: #8a94a6; margin-bottom: 28px; }\n.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px; }\n.stat-card { background: #fff; border-radius: 12px; padding: 20px; border: 1px solid #e8ecf4; }\n.stat-label { font-size: 13px; color: #8a94a6; margin-bottom: 8px; }\n.stat-value { font-size: 28px; font-weight: 600; color: #1a1a2e; }\n.stat-value.blue { color: #4f8ef7; }\n.stat-value.amber { color: #f59e0b; }\n.stat-value.green { color: #10b981; }\n.card { background: #fff; border-radius: 12px; border: 1px solid #e8ecf4; padding: 24px; }\n.form-group { margin-bottom: 18px; }\n.form-label { display: block; font-size: 13px; font-weight: 500; color: #4a5568; margin-bottom: 6px; }\n.form-input { width: 100%; padding: 10px 14px; border: 1px solid #dde3ee; border-radius: 8px; font-size: 14px; font-family: 'DM Sans', sans-serif; outline: none; transition: border 0.15s; color: #1a1a2e; background: #fff; }\n.form-input:focus { border-color: #4f8ef7; box-shadow: 0 0 0 3px rgba(79,142,247,0.1); }\n.form-input.invalid { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,0.1); }\n.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }\n.btn { padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; border: none; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }\n.btn-primary { background: #4f8ef7; color: #fff; }\n.btn-primary:hover { background: #3a7ce8; }\n.btn-primary:disabled { background: #a0b8f0; cursor: not-allowed; }\n.btn-sm { padding: 6px 14px; font-size: 13px; }\n.btn-confirm { background: #10b981; color: #fff; }\n.btn-confirm:hover { background: #059669; }\n.btn-danger { background: #fee2e2; color: #991b1b; }\n.alert { padding: 12px 16px; border-radius: 8px; font-size: 14px; margin-bottom: 20px; display: none; }\n.alert-success { background: #d1fae5; color: #065f46; }\n.alert-error { background: #fee2e2; color: #991b1b; }\n.alert-info { background: #dbeafe; color: #1e40af; }\n.search-bar { margin-bottom: 20px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }\n.table-wrap { overflow-x: auto; }\ntable { width: 100%; border-collapse: collapse; font-size: 14px; }\nth { text-align: left; padding: 10px 14px; font-size: 12px; font-weight: 500; color: #8a94a6; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #e8ecf4; }\ntd { padding: 13px 14px; border-bottom: 1px solid #f0f3f9; color: #2d3748; vertical-align: middle; }\ntr:last-child td { border-bottom: none; }\ntr:hover td { background: #f8faff; }\n.badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 500; }\n.badge-waiting { background: #fef3c7; color: #92400e; }\n.badge-done { background: #d1fae5; color: #065f46; }\n.empty-state { text-align: center; padding: 48px 20px; color: #8a94a6; }\n.modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 100; }\n.modal-overlay.open { display: flex; }\n.modal { background: #fff; border-radius: 14px; padding: 28px; width: 400px; max-width: 90vw; }\n.modal h3 { font-size: 17px; font-weight: 600; color: #1a1a2e; margin-bottom: 6px; }\n.modal p { font-size: 14px; color: #8a94a6; margin-bottom: 20px; }\n.modal-actions { display: flex; gap: 10px; justify-content: flex-end; }\n.btn-cancel { background: #f4f6fb; color: #4a5568; }\n.loading { text-align: center; padding: 40px; color: #8a94a6; font-size: 14px; }\n.url-indicator { background: #f0f3f9; border-left: 4px solid #4f8ef7; padding: 12px 14px; border-radius: 6px; margin-bottom: 16px; font-size: 12px; color: #4a5568; word-break: break-all; }\n.url-indicator-label { font-size: 11px; color: #8a94a6; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; font-weight: 500; }\n.btn-group { display: flex; gap: 8px; margin-top: 16px; flex-wrap: wrap; }\n.btn-secondary { background: #e8ecf4; color: #4a5568; }\n.btn-secondary:hover { background: #d8dfe8; }\n.debug-log { background: #1a1a2e; color: #4f8ef7; padding: 12px; border-radius: 6px; font-family: 'Courier New', monospace; font-size: 11px; line-height: 1.4; margin-top: 20px; max-height: 200px; overflow-y: auto; }\n.debug-log-item { margin-bottom: 4px; }\n.debug-log-time { color: #8a94a6; }\n.debug-log-success { color: #10b981; }\n.debug-log-error { color: #f59e0b; }\n.history-list { margin-top: 12px; padding: 12px; background: #f8faff; border-radius: 6px; }\n.history-item { display: flex; justify-content: space-between; align-items: center; padding: 8px; background: #fff; border: 1px solid #e8ecf4; border-radius: 4px; margin-bottom: 6px; font-size: 12px; gap: 10px; }\n.history-item-url { word-break: break-all; flex: 1; color: #4a5568; }\n.history-item-btn { background: #4f8ef7; color: #fff; border: none; padding: 4px 10px; border-radius: 3px; cursor: pointer; font-size: 11px; }\n@media (max-width: 820px) {\n  body { display: block; }\n  .sidebar { width: 100%; min-height: auto; }\n  .nav { display: grid; grid-template-columns: repeat(3, 1fr); }\n  .nav-item { padding: 10px 12px; font-size: 13px; }\n  .main { padding: 20px; }\n  .stats-grid, .form-row { grid-template-columns: 1fr; }\n}\n</style>\n</head>\n<body>\n\n<div class=\"sidebar\">\n  <div class=\"sidebar-logo\">\n    <h1>Receb<span>AI</span></h1>\n    <p>Gestão de Encomendas</p>\n  </div>\n  <nav class=\"nav\">\n    <div class=\"nav-item active\" onclick=\"navigate('dashboard')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/></svg>\n      Dashboard\n    </div>\n    <div class=\"nav-item\" onclick=\"navigate('portaria')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path d=\"M12 2l7 4v6c0 5-7 10-7 10S5 17 5 12V6l7-4z\"/></svg>\n      Portaria\n    </div>\n    <div class=\"nav-item\" onclick=\"navigate('encomendas')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path d=\"M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z\"/><path d=\"M16 3H8l-2 4h12l-2-4z\"/></svg>\n      Encomendas\n    </div>\n    <div class=\"nav-item\" onclick=\"navigate('historico')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 6v6l4 2\"/></svg>\n      Histórico\n    </div>\n    <div class=\"nav-item\" onclick=\"navigate('moradores')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path d=\"M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 00-3-3.87\"/><path d=\"M16 3.13a4 4 0 010 7.75\"/></svg>\n      Moradores\n    </div>\n    <div class=\"nav-item\" onclick=\"navigate('configuracoes')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"1\"/><path d=\"M12 1v6m0 6v6M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24M1 12h6m6 0h6m-17.78 7.78l4.24-4.24m5.08-5.08l4.24-4.24\"/></svg>\n      Configurações\n    </div>\n  </nav>\n</div>\n\n<main class=\"main\">\n\n  <div id=\"dashboard\" class=\"page active\">\n    <div class=\"page-title\">Dashboard</div>\n    <div class=\"page-sub\">Resumo geral das encomendas</div>\n    <div id=\"dashboard-alert\" class=\"alert\"></div>\n    <div class=\"stats-grid\">\n      <div class=\"stat-card\"><div class=\"stat-label\">Total de Encomendas</div><div class=\"stat-value blue\" id=\"stat-total\">0</div></div>\n      <div class=\"stat-card\"><div class=\"stat-label\">Aguardando Retirada</div><div class=\"stat-value amber\" id=\"stat-aguardando\">0</div></div>\n      <div class=\"stat-card\"><div class=\"stat-label\">Retiradas Hoje</div><div class=\"stat-value green\" id=\"stat-hoje\">0</div></div>\n    </div>\n    <div class=\"card\">\n      <div style=\"font-size:15px;font-weight:500;color:#1a1a2e;margin-bottom:16px\">Encomendas aguardando retirada</div>\n      <div id=\"dashboard-pending\"><div class=\"loading\">Carregando...</div></div>\n    </div>\n  </div>\n\n  <div id=\"portaria\" class=\"page\">\n    <div class=\"page-title\">Registrar Encomenda</div>\n    <div class=\"page-sub\">Preencha os dados da encomenda que chegou na portaria</div>\n    <div class=\"card\" style=\"max-width:580px\">\n      <div id=\"form-alert\" class=\"alert\"></div>\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label class=\"form-label\">Código de Rastreio</label>\n          <input class=\"form-input\" id=\"f-tracking\" autocomplete=\"off\" placeholder=\"BR123456789BR\" />\n        </div>\n        <div class=\"form-group\">\n          <label class=\"form-label\">Transportadora</label>\n          <input class=\"form-input\" id=\"f-transportadora\" autocomplete=\"off\" placeholder=\"Correios, Jadlog...\" />\n        </div>\n      </div>\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label class=\"form-label\">Nome do Destinatário</label>\n          <input class=\"form-input\" id=\"f-nome\" autocomplete=\"off\" list=\"moradores-list\" placeholder=\"João Silva\" oninput=\"preencherMoradorPorNome()\" />\n          <datalist id=\"moradores-list\"></datalist>\n        </div>\n        <div class=\"form-group\">\n          <label class=\"form-label\">Unidade / Apto</label>\n          <input class=\"form-input\" id=\"f-unidade\" autocomplete=\"off\" placeholder=\"Apto 42 - Bloco B\" />\n        </div>\n      </div>\n      <button class=\"btn btn-primary\" id=\"btn-registrar\" onclick=\"registrarEncomenda()\">Registrar Encomenda</button>\n    </div>\n  </div>\n\n  <div id=\"encomendas\" class=\"page\">\n    <div class=\"page-title\">Encomendas</div>\n    <div class=\"page-sub\">Todas as encomendas registradas</div>\n    <div class=\"search-bar\">\n      <input class=\"form-input\" id=\"search-input\" placeholder=\"Buscar por nome, unidade ou código...\" oninput=\"filterTable()\" style=\"max-width:340px\" />\n      <button class=\"btn btn-secondary\" onclick=\"loadEncomendas()\">Atualizar</button>\n    </div>\n    <div class=\"card\">\n      <div id=\"encomendas-table\"><div class=\"loading\">Carregando...</div></div>\n    </div>\n  </div>\n\n  <div id=\"historico\" class=\"page\">\n    <div class=\"page-title\">Histórico</div>\n    <div class=\"page-sub\">Encomendas já retiradas</div>\n    <div class=\"card\">\n      <div id=\"historico-table\"><div class=\"loading\">Carregando...</div></div>\n    </div>\n  </div>\n\n  <div id=\"moradores\" class=\"page\">\n    <div class=\"page-title\">Cadastro de Moradores</div>\n    <div class=\"page-sub\">Cadastre os moradores do condomínio</div>\n    <div class=\"card\" style=\"max-width:580px; margin-bottom:28px\">\n      <div id=\"morador-alert\" class=\"alert\"></div>\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label class=\"form-label\">Nome completo</label>\n          <input class=\"form-input\" id=\"m-nome\" autocomplete=\"off\" placeholder=\"João Silva\" />\n        </div>\n        <div class=\"form-group\">\n          <label class=\"form-label\">CPF</label>\n          <input class=\"form-input\" id=\"m-cpf\" autocomplete=\"off\" placeholder=\"000.000.000-00\" />\n        </div>\n      </div>\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label class=\"form-label\">Celular (WhatsApp)</label>\n          <input class=\"form-input\" id=\"m-celular\" inputmode=\"numeric\" autocomplete=\"off\" placeholder=\"21999999999 (com DDD)\" />\n        </div>\n        <div class=\"form-group\">\n          <label class=\"form-label\">Unidade / Apto</label>\n          <input class=\"form-input\" id=\"m-unidade\" autocomplete=\"off\" placeholder=\"Apto 42 - Bloco B\" />\n        </div>\n      </div>\n      <button class=\"btn btn-primary\" id=\"btn-cadastrar-morador\" onclick=\"cadastrarMorador()\">Cadastrar Morador</button>\n    </div>\n    <div class=\"card\">\n      <div style=\"font-size:15px;font-weight:500;color:#1a1a2e;margin-bottom:16px\">Moradores cadastrados</div>\n      <div id=\"moradores-table\"><div class=\"loading\">Carregando...</div></div>\n    </div>\n  </div>\n\n  <div id=\"configuracoes\" class=\"page\">\n    <div class=\"page-title\">Configurações</div>\n    <div class=\"page-sub\">Configure os parâmetros da aplicação</div>\n    <div class=\"card\" style=\"max-width:640px\">\n      <div id=\"config-alert\" class=\"alert\"></div>\n\n      <div style=\"background:#e8f5ff;border:1px solid #b3e5fc;border-radius:8px;padding:12px;margin-bottom:20px\">\n        <div class=\"url-indicator-label\" style=\"color:#01579b\">URL Ativa No Momento</div>\n        <div class=\"url-indicator\" style=\"background:#fff;border-left-color:#01579b;color:#01579b\" id=\"url-active\">Carregando...</div>\n      </div>\n\n      <div class=\"form-group\">\n        <label class=\"form-label\">URL Base da API</label>\n        <input class=\"form-input\" id=\"config-api-base\" placeholder=\"http://localhost:5678/webhook\" />\n        <p style=\"font-size:12px;color:#8a94a6;margin-top:6px\">Use a base do n8n, sem barra final. Exemplo local: http://localhost:5678/webhook</p>\n      </div>\n\n      <div class=\"btn-group\">\n        <button class=\"btn btn-primary\" onclick=\"salvarConfiguracao()\">Salvar Configuração</button>\n        <button class=\"btn btn-secondary\" onclick=\"testarConexao()\">Testar Conexão</button>\n        <button class=\"btn btn-danger\" onclick=\"resetarConfiguracao()\">Resetar</button>\n      </div>\n\n      <div style=\"margin-top:24px;border-top:1px solid #e8ecf4;padding-top:20px\">\n        <div style=\"font-size:13px;font-weight:500;color:#1a1a2e;margin-bottom:12px\">Histórico de URLs</div>\n        <div id=\"history-container\" class=\"history-list\">\n          <div style=\"text-align:center;color:#8a94a6;font-size:12px;padding:20px\">Nenhuma URL anterior salva</div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:24px;border-top:1px solid #e8ecf4;padding-top:20px\">\n        <div style=\"font-size:13px;font-weight:500;color:#1a1a2e;margin-bottom:8px\">Log de Debug</div>\n        <button class=\"btn btn-secondary\" style=\"font-size:12px;padding:6px 12px;margin-bottom:12px\" onclick=\"limparLog()\">Limpar Log</button>\n        <div class=\"debug-log\" id=\"debug-log\">\n          <div class=\"debug-log-item\"><span class=\"debug-log-time\">[00:00]</span> Sistema iniciado</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n</main>\n\n<div class=\"modal-overlay\" id=\"modal-overlay\">\n  <div class=\"modal\">\n    <h3>Confirmar Retirada</h3>\n    <p>Informe o nome de quem está retirando a encomenda.</p>\n    <div class=\"form-group\">\n      <input class=\"form-input\" id=\"modal-retirada-por\" placeholder=\"Nome de quem retirou\" />\n    </div>\n    <div class=\"modal-actions\">\n      <button class=\"btn btn-cancel\" onclick=\"closeModal()\">Cancelar</button>\n      <button class=\"btn btn-confirm\" onclick=\"confirmarRetirada()\">Confirmar</button>\n    </div>\n  </div>\n</div>\n\n<script>\nconst DEFAULT_API_BASE = 'https://pdrzinn.app.n8n.cloud/webhook';\nlet API_BASE = DEFAULT_API_BASE;\nlet allEncomendas = [];\nlet allMoradores = [];\nlet currentRetiradaId = null;\nlet urlHistory = [];\n\nfunction $(id) { return document.getElementById(id); }\n\nfunction adicionarLog(mensagem, tipo) {\n  const logEl = $('debug-log');\n  if (!logEl) return;\n  const time = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });\n  const className = tipo === 'success' ? 'debug-log-success' : tipo === 'error' ? 'debug-log-error' : '';\n  const item = document.createElement('div');\n  item.className = 'debug-log-item';\n  item.innerHTML = '<span class=\"debug-log-time\">[' + time + ']</span> <span class=\"' + className + '\">' + escapeHtml(mensagem) + '</span>';\n  logEl.appendChild(item);\n  logEl.scrollTop = logEl.scrollHeight;\n}\n\nfunction escapeHtml(value) {\n  return String(value ?? '').replace(/[&<>\"']/g, function(ch) {\n    return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;', \"'\": '&#39;' })[ch];\n  });\n}\n\nfunction normalizeApiBase(value) {\n  return String(value || '').trim().replace(/\\/+$/, '');\n}\n\nfunction getApiBaseFromUrl() {\n  const params = new URLSearchParams(window.location.search);\n  return params.get('api') || params.get('api_base') || '';\n}\n\nfunction carregarConfiguracao() {\n  const queryBase = getApiBaseFromUrl();\n  const savedBase = localStorage.getItem('api_base');\n  const savedHistory = localStorage.getItem('url_history');\n\n  if (savedHistory) {\n    try { urlHistory = JSON.parse(savedHistory) || []; } catch(e) { urlHistory = []; }\n  }\n\n  API_BASE = normalizeApiBase(queryBase || savedBase || DEFAULT_API_BASE);\n  if (queryBase) localStorage.setItem('api_base', API_BASE);\n\n  adicionarLog('API ativa: ' + API_BASE, 'info');\n  atualizarIndicadorUrl();\n}\n\nfunction navigate(page) {\n  document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });\n  document.querySelectorAll('.nav-item').forEach(function(n) { n.classList.remove('active'); });\n  $(page).classList.add('active');\n  const pages = ['dashboard','portaria','encomendas','historico','moradores','configuracoes'];\n  const idx = pages.indexOf(page);\n  if (idx >= 0) document.querySelectorAll('.nav-item')[idx].classList.add('active');\n  if (page === 'dashboard') loadDashboard();\n  if (page === 'portaria') ensureMoradores();\n  if (page === 'encomendas') loadEncomendas();\n  if (page === 'historico') loadHistorico();\n  if (page === 'moradores') loadMoradores();\n  if (page === 'configuracoes') loadConfiguracoes();\n}\n\nfunction loadConfiguracoes() {\n  $('config-api-base').value = API_BASE;\n  atualizarIndicadorUrl();\n  renderizarHistorico();\n}\n\nfunction atualizarIndicadorUrl() {\n  const indicator = $('url-active');\n  if (indicator) indicator.textContent = API_BASE;\n}\n\nfunction salvarConfiguracao() {\n  const novaUrl = normalizeApiBase($('config-api-base').value);\n  const alertEl = $('config-alert');\n  if (!novaUrl) {\n    showAlert(alertEl, 'error', 'Por favor, insira uma URL válida.');\n    return;\n  }\n  try {\n    new URL(novaUrl);\n    if (novaUrl !== API_BASE && !urlHistory.includes(novaUrl)) {\n      urlHistory.unshift(novaUrl);\n      if (urlHistory.length > 10) urlHistory.pop();\n      localStorage.setItem('url_history', JSON.stringify(urlHistory));\n    }\n    API_BASE = novaUrl;\n    localStorage.setItem('api_base', novaUrl);\n    showAlert(alertEl, 'success', 'Configuração salva com sucesso.');\n    adicionarLog('Nova URL salva: ' + novaUrl, 'success');\n    atualizarIndicadorUrl();\n    renderizarHistorico();\n  } catch(e) {\n    showAlert(alertEl, 'error', 'URL inválida. Verifique e tente novamente.');\n    adicionarLog('URL inválida: ' + novaUrl, 'error');\n  }\n}\n\nfunction resetarConfiguracao() {\n  localStorage.removeItem('api_base');\n  API_BASE = DEFAULT_API_BASE;\n  $('config-api-base').value = API_BASE;\n  atualizarIndicadorUrl();\n  showAlert($('config-alert'), 'info', 'Configuração resetada para localhost.');\n}\n\nasync function testarConexao() {\n  const alertEl = $('config-alert');\n  const btn = document.querySelector('button[onclick=\"testarConexao()\"]');\n  const btnOriginal = btn.textContent;\n  btn.disabled = true;\n  btn.textContent = 'Testando...';\n  adicionarLog('Testando conexão com: ' + API_BASE, 'info');\n  try {\n    const data = await apiGet('/recebai/stats');\n    if (!data || typeof data !== 'object') throw new Error('Resposta inválida');\n    showAlert(alertEl, 'success', 'Conexão OK. API respondendo JSON.');\n    adicionarLog('Conexão bem-sucedida com a API', 'success');\n  } catch(e) {\n    showAlert(alertEl, 'error', 'Erro ao conectar: ' + e.message);\n    adicionarLog('Erro na conexão: ' + e.message, 'error');\n  } finally {\n    btn.disabled = false;\n    btn.textContent = btnOriginal;\n  }\n}\n\nfunction renderizarHistorico() {\n  const container = $('history-container');\n  if (!container) return;\n  if (urlHistory.length === 0) {\n    container.innerHTML = '<div style=\"text-align:center;color:#8a94a6;font-size:12px;padding:20px\">Nenhuma URL anterior salva</div>';\n    return;\n  }\n  container.innerHTML = urlHistory.map(function(url) {\n    return '<div class=\"history-item\"><div class=\"history-item-url\">' + escapeHtml(url) + '</div><button class=\"history-item-btn\" onclick=\"restaurarUrl(\\'' + escapeHtml(url) + '\\')\">Usar</button></div>';\n  }).join('');\n}\n\nfunction restaurarUrl(url) {\n  $('config-api-base').value = url;\n  adicionarLog('URL do histórico restaurada para o campo de entrada', 'info');\n}\n\nfunction limparLog() {\n  const logEl = $('debug-log');\n  if (logEl) logEl.innerHTML = '<div class=\"debug-log-item\"><span class=\"debug-log-time\">[00:00]</span> Log limpo</div>';\n}\n\nasync function apiGet(path) {\n  const res = await fetch(API_BASE + path, { method: 'GET' });\n  return parseResponse(res);\n}\n\nasync function apiPost(path, payload) {\n  const res = await fetch(API_BASE + path, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(payload)\n  });\n  return parseResponse(res);\n}\n\nasync function parseResponse(res) {\n  const text = await res.text();\n  let data = null;\n  if (text) {\n    try { data = JSON.parse(text); } catch(e) { throw new Error('A API respondeu texto, não JSON. Status ' + res.status); }\n  }\n  if (!res.ok) {\n    const detail = data && (data.message || data.error) ? ': ' + (data.message || data.error) : '';\n    throw new Error('HTTP ' + res.status + detail);\n  }\n  return data ?? (Array.isArray(data) ? [] : {});\n}\n\nfunction asArray(payload) {\n  if (Array.isArray(payload)) return payload;\n  if (payload && Array.isArray(payload.items)) return payload.items;\n  if (payload && Array.isArray(payload.data)) return payload.data;\n  return [];\n}\n\nasync function loadDashboard() {\n  const alertEl = $('dashboard-alert');\n  try {\n    const statsPromise = apiGet('/recebai/stats');\n    const encomendasPromise = apiGet('/recebai/encomendas?status=aguardando_retirada');\n    const result = await Promise.all([statsPromise, encomendasPromise]);\n    const stats = Array.isArray(result[0]) ? result[0][0] || {} : result[0] || {};\n    const pending = asArray(result[1]).filter(validPackageRow);\n    $('stat-total').textContent = stats.total ?? 0;\n    $('stat-aguardando').textContent = stats.aguardando ?? 0;\n    $('stat-hoje').textContent = stats.retirado_hoje ?? 0;\n    $('dashboard-pending').innerHTML = pending.length ? renderTable(pending, false) : '<div class=\"empty-state\">Nenhuma encomenda aguardando retirada</div>';\n    hideAlert(alertEl);\n  } catch(e) {\n    $('dashboard-pending').innerHTML = '<div class=\"empty-state\">Não foi possível carregar os dados</div>';\n    showAlert(alertEl, 'error', 'Falha ao carregar dashboard: ' + e.message);\n    adicionarLog('Dashboard falhou: ' + e.message, 'error');\n  }\n}\n\nasync function loadEncomendas() {\n  try {\n    const data = await apiGet('/recebai/encomendas');\n    allEncomendas = asArray(data).filter(validPackageRow);\n    renderEncomendasTable();\n  } catch(e) {\n    $('encomendas-table').innerHTML = '<div class=\"empty-state\">Erro ao carregar encomendas</div>';\n    adicionarLog('Erro ao carregar encomendas: ' + e.message, 'error');\n  }\n}\n\nasync function loadHistorico() {\n  try {\n    const data = await apiGet('/recebai/encomendas?status=retirado');\n    const rows = asArray(data).filter(validPackageRow);\n    $('historico-table').innerHTML = rows.length ? renderTable(rows, false) : '<div class=\"empty-state\">Nenhuma encomenda retirada ainda</div>';\n  } catch(e) {\n    $('historico-table').innerHTML = '<div class=\"empty-state\">Erro ao carregar histórico</div>';\n    adicionarLog('Erro ao carregar histórico: ' + e.message, 'error');\n  }\n}\n\nasync function ensureMoradores() {\n  if (allMoradores.length === 0) await loadMoradores(false);\n}\n\nasync function loadMoradores(renderTableNow) {\n  if (renderTableNow === undefined) renderTableNow = true;\n  try {\n    const data = await apiGet('/recebai/moradores');\n    allMoradores = asArray(data).filter(function(m) { return m.id && m.id !== 'id'; });\n    renderMoradoresDatalist();\n    if (renderTableNow) renderMoradoresTable();\n  } catch(e) {\n    if (renderTableNow) $('moradores-table').innerHTML = '<div class=\"empty-state\">Erro ao carregar moradores</div>';\n    adicionarLog('Erro ao carregar moradores: ' + e.message, 'error');\n  }\n}\n\nfunction renderMoradoresDatalist() {\n  const list = $('moradores-list');\n  list.innerHTML = allMoradores.map(function(m) {\n    return '<option value=\"' + escapeHtml(m.nome || '') + '\">' + escapeHtml(m.unidade || '') + '</option>';\n  }).join('');\n}\n\nfunction renderMoradoresTable() {\n  const el = $('moradores-table');\n  if (allMoradores.length === 0) {\n    el.innerHTML = '<div class=\"empty-state\">Nenhum morador cadastrado ainda</div>';\n    return;\n  }\n  const header = '<div class=\"table-wrap\"><table><thead><tr><th>Nome</th><th>CPF</th><th>Celular</th><th>Unidade</th></tr></thead><tbody>';\n  const body = allMoradores.map(function(m) {\n    return '<tr><td>' + escapeHtml(m.nome || '-') + '</td><td>' + escapeHtml(m.cpf || '-') + '</td><td>' + escapeHtml(formatPhone(m.celular)) + '</td><td>' + escapeHtml(m.unidade || '-') + '</td></tr>';\n  }).join('');\n  el.innerHTML = header + body + '</tbody></table></div>';\n}\n\nfunction preencherMoradorPorNome() {\n  const nome = $('f-nome').value.trim().toLowerCase();\n  if (!nome) return;\n  const morador = allMoradores.find(function(m) {\n    return String(m.nome || '').trim().toLowerCase() === nome;\n  });\n  if (!morador) return;\n  $('f-unidade').value = morador.unidade || $('f-unidade').value;\n}\n\nfunction filterTable() {\n  const q = $('search-input').value.toLowerCase();\n  const filtered = allEncomendas.filter(function(e) {\n    return String(e.destinatario_nome || '').toLowerCase().includes(q)\n      || String(e.destinatario_unidade || '').toLowerCase().includes(q)\n      || String(e.tracking_code || '').toLowerCase().includes(q);\n  });\n  $('encomendas-table').innerHTML = filtered.length ? renderTable(filtered, true) : '<div class=\"empty-state\">Nenhum resultado encontrado</div>';\n}\n\nfunction renderEncomendasTable() {\n  $('encomendas-table').innerHTML = allEncomendas.length ? renderTable(allEncomendas, true) : '<div class=\"empty-state\">Nenhuma encomenda cadastrada</div>';\n}\n\nfunction renderTable(rows, showAction) {\n  const header = '<div class=\"table-wrap\"><table><thead><tr><th>Código</th><th>Destinatário</th><th>Unidade</th><th>Transportadora</th><th>Status</th><th>Chegada</th>' + (showAction ? '<th>Ação</th>' : '') + '</tr></thead><tbody>';\n  const body = rows.map(function(r) {\n    const isWaiting = r.status === 'aguardando_retirada';\n    const badge = isWaiting ? '<span class=\"badge badge-waiting\">Aguardando</span>' : '<span class=\"badge badge-done\">Retirado</span>';\n    const action = showAction && isWaiting ? '<button class=\"btn btn-sm btn-confirm\" onclick=\"openModal(\\'' + escapeHtml(r.id) + '\\')\">Confirmar Retirada</button>' : (showAction ? '<span style=\"color:#8a94a6;font-size:13px\">-</span>' : '');\n    const date = r.created_at ? new Date(r.created_at).toLocaleDateString('pt-BR') : '-';\n    return '<tr><td style=\"font-family:monospace;font-size:13px\">' + escapeHtml(r.tracking_code || '-') + '</td><td>' + escapeHtml(r.destinatario_nome || '-') + '</td><td>' + escapeHtml(r.destinatario_unidade || '-') + '</td><td>' + escapeHtml(r.transportadora || '-') + '</td><td>' + badge + '</td><td>' + escapeHtml(date) + '</td>' + (showAction ? '<td>' + action + '</td>' : '') + '</tr>';\n  }).join('');\n  return header + body + '</tbody></table></div>';\n}\n\nasync function registrarEncomenda() {\n  const tracking = $('f-tracking').value.trim();\n  const nome = $('f-nome').value.trim();\n  const unidade = $('f-unidade').value.trim();\n  const transp = $('f-transportadora').value.trim();\n  const alertEl = $('form-alert');\n\n  clearInvalid(['f-tracking','f-nome','f-unidade','f-transportadora']);\n  const invalid = [];\n  if (!tracking) invalid.push('f-tracking');\n  if (!nome) invalid.push('f-nome');\n  if (!unidade) invalid.push('f-unidade');\n  if (!transp) invalid.push('f-transportadora');\n  if (invalid.length) {\n    markInvalid(invalid);\n    showAlert(alertEl, 'error', 'Preencha código, nome, unidade e transportadora.');\n    return;\n  }\n\n  const btn = $('btn-registrar');\n  btn.disabled = true;\n  btn.textContent = 'Registrando...';\n  try {\n    await apiPost('/recebai/encomendas', {\n      tracking_code: tracking,\n      destinatario_nome: nome,\n      destinatario_unidade: unidade,\n      transportadora: transp\n    });\n    showAlert(alertEl, 'success', 'Encomenda registrada com sucesso.');\n    ['f-tracking','f-nome','f-unidade','f-transportadora'].forEach(function(id) { $(id).value = ''; });\n    loadDashboard();\n  } catch(e) {\n    showAlert(alertEl, 'error', 'Erro ao registrar: ' + e.message);\n    adicionarLog('Registro falhou: ' + e.message, 'error');\n  } finally {\n    btn.disabled = false;\n    btn.textContent = 'Registrar Encomenda';\n  }\n}\n\nasync function cadastrarMorador() {\n  const nome = $('m-nome').value.trim();\n  const cpf = $('m-cpf').value.trim();\n  const celular = $('m-celular').value.trim();\n  const unidade = $('m-unidade').value.trim();\n  const alertEl = $('morador-alert');\n\n  clearInvalid(['m-nome','m-celular','m-unidade']);\n  const invalid = [];\n  if (!nome) invalid.push('m-nome');\n  if (!validBrazilPhone(celular)) invalid.push('m-celular');\n  if (!unidade) invalid.push('m-unidade');\n  if (invalid.length) {\n    markInvalid(invalid);\n    showAlert(alertEl, 'error', 'Preencha nome, celular com DDD e unidade.');\n    return;\n  }\n\n  const btn = $('btn-cadastrar-morador');\n  btn.disabled = true;\n  btn.textContent = 'Cadastrando...';\n  try {\n    await apiPost('/recebai/moradores', { nome: nome, cpf: cpf, celular: celular, unidade: unidade });\n    showAlert(alertEl, 'success', 'Morador cadastrado com sucesso.');\n    ['m-nome','m-cpf','m-celular','m-unidade'].forEach(function(id) { $(id).value = ''; });\n    loadMoradores();\n  } catch(e) {\n    showAlert(alertEl, 'error', 'Erro ao cadastrar: ' + e.message);\n    adicionarLog('Cadastro de morador falhou: ' + e.message, 'error');\n  } finally {\n    btn.disabled = false;\n    btn.textContent = 'Cadastrar Morador';\n  }\n}\n\nfunction showAlert(el, type, msg) {\n  if (!el) return;\n  el.className = 'alert alert-' + type;\n  el.textContent = msg;\n  el.style.display = 'block';\n}\n\nfunction hideAlert(el) {\n  if (el) el.style.display = 'none';\n}\n\nfunction onlyDigits(value) {\n  return String(value || '').replace(/\\D/g, '');\n}\n\nfunction validBrazilPhone(value) {\n  const digits = onlyDigits(value);\n  return digits.length === 10 || digits.length === 11 || (digits.startsWith('55') && (digits.length === 12 || digits.length === 13));\n}\n\nfunction formatPhone(value) {\n  const digits = onlyDigits(value);\n  if (!digits) return '-';\n  return digits.startsWith('55') ? '+' + digits : digits;\n}\n\nfunction clearInvalid(ids) {\n  ids.forEach(function(id) { $(id).classList.remove('invalid'); });\n}\n\nfunction markInvalid(ids) {\n  ids.forEach(function(id) { $(id).classList.add('invalid'); });\n}\n\nfunction validPackageRow(row) {\n  return row && row.id && row.id !== 'id';\n}\n\nfunction openModal(id) {\n  currentRetiradaId = id;\n  $('modal-retirada-por').value = '';\n  $('modal-overlay').classList.add('open');\n}\n\nfunction closeModal() {\n  $('modal-overlay').classList.remove('open');\n  currentRetiradaId = null;\n}\n\nasync function confirmarRetirada() {\n  const nome = $('modal-retirada-por').value.trim();\n  if (!nome) {\n    alert('Informe o nome de quem está retirando.');\n    return;\n  }\n  try {\n    await apiPost('/recebai/encomendas/retirar', { id: currentRetiradaId, retirada_por: nome });\n    closeModal();\n    await Promise.all([loadEncomendas(), loadDashboard()]);\n  } catch(e) {\n    alert('Erro ao confirmar retirada: ' + e.message);\n  }\n}\n\ncarregarConfiguracao();\nloadDashboard();\nensureMoradores();\n</script>\n</body>\n</html>\n",
