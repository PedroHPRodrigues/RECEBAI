    {
      "parameters": {
        "jsCode": "function normalizeText(value) {\n  return String(value || '').trim().replace(/\\s+/g, ' ');\n}\n\nconst body = $('POST /recebai/encomendas/retirar').first().json.body || {};\nconst targetId = normalizeText(body.id);\nconst retiradaPor = normalizeText(body.retirada_por || body.retirado_por || body.nome);\n\nif (!targetId) throw new Error('id da encomenda e obrigatorio');\nif (!retiradaPor) throw new Error('retirada_por e obrigatorio');\n\nconst rows = $input.all();\nconst rowIndex = rows.findIndex((row) => String(row.json.id || '').trim() === targetId);\nif (rowIndex === -1) throw new Error('Encomenda nao encontrada: ' + targetId);\n\nconst row = rows[rowIndex].json;\nreturn [{\n  json: {\n    ...row,\n    id: targetId,\n    status: 'retirado',\n    retirada_at: new Date().toISOString(),\n    retirada_por: retiradaPor,\n    _rowNumber: rowIndex + 2\n  }\n}];"
      },
